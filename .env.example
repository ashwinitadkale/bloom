# ── Bloom Environment Variables ───────────────────────────────────────────────
# Copy this file to .env and fill in your values.

# Flask/Starlette secret key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-me-to-a-random-secret-string

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default — zero config, great for local dev):
DATABASE_URL=sqlite+aiosqlite:///./instance/bloom.db

# PostgreSQL (recommended for production):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/bloom_db

# ── AI Chatbot ────────────────────────────────────────────────────────────────
# Get a FREE key at: https://console.groq.com
# Without this, Bloom falls back to smart rule-based responses.
GROQ_API_KEY=

# Groq model to use (llama3-8b-8192 is fast and free)
GROQ_MODEL=llama3-8b-8192

# ── App settings ──────────────────────────────────────────────────────────────
DEBUG=false
